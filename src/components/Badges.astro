---
// 88x31 Badges
const badges = [
{ src: "/badges/neovim.gif", alt: "Made with Neovim", href: "https://neovim.io/" },
// { src: "/badges/vim.gif", alt: "Made with Vim", href: "https://www.vim.org/" },

{ src: "/badges/gnu.gif", alt: "GNU", href: "https://www.gnu.org/" },
{ src: "/badges/gnu-linux.gif", alt: "GNU/Linux", href: "https://www.gnu.org/" },
// { src: "/badges/linux.gif", alt: "Linux", href: "https://www.linux.org/" },
{ src: "/badges/archlinux.gif", alt: "Arch Linux", href: "https://archlinux.org/" },
{ src: "/badges/macos.gif", alt: "macOS", href: "https://www.apple.com/macos/" },

{ src: "/badges/nojs.gif", alt: "No JavaScript", href: "https://www.gnu.org/philosophy/javascript-trap.html" },
{ src: "/badges/antinazi.gif", alt: "Anti-fascist", href: "https://en.wikipedia.org/wiki/Anti-fascism" },
{ src: "/badges/adhd.png", alt: "ADHD", href: "https://en.wikipedia.org/wiki/Attention-deficit_hyperactivity_disorder" },

{ src: "/badges/spotify.gif", alt: "Spotify", href: "https://open.spotify.com/user/31cscbv4s256ppqweoixud5hxq6q" },
// { src: "/badges/github.gif", alt: "GitHub", href: "https://github.com/3p5ilon" },
{ src: "/badges/discord.gif", alt: "Discord", href: "https://discord.com/users/1175830916975841364" },
];
---
<div class="flex w-full overflow-hidden group h-[31px]">
  <div class="flex w-max flex-shrink-0 animate-marquee gap-2 pr-2">
    {badges.map((b) => (
      <a href={b.href} target="_blank" rel="noopener noreferrer" class="hover:opacity-80 transition-opacity flex-shrink-0">
        <img src={b.src} alt={b.alt} width="88" height="31" class="pixelated block" />
      </a>
    ))}
  </div>
  <div class="flex w-max flex-shrink-0 animate-marquee gap-2 pr-2" aria-hidden="true">
    {badges.map((b) => (
      <a href={b.href} target="_blank" rel="noopener noreferrer" class="hover:opacity-80 transition-opacity flex-shrink-0">
        <img src={b.src} alt={b.alt} width="88" height="31" class="pixelated block" />
      </a>
    ))}
  </div>
</div>

<style>

  .pixelated {
    image-rendering: pixelated;
  }
  
  .animate-marquee {
    animation: marquee 20s linear infinite;
  }
  
  .group:hover .animate-marquee {
    animation-play-state: paused;
  }

  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-100%);
    }
  }
</style>
