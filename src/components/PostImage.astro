---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: string | ImageMetadata;
  alt?: string;
  caption?: string;
  title?: string;
  class?: string;
  loading?: "lazy" | "eager";
}

const { src, alt = "", caption, title, class: className = "", loading = "lazy" } = Astro.props;
const displayCaption = caption || title;
const isImageMetadata = typeof src === "object" && src !== null && "src" in src;
---

<figure class={`my-6 space-y-2 ${className}`}>
  {
    isImageMetadata ? (
      <Image
        src={src as ImageMetadata}
        alt={alt || title || ""}
        title={title}
        loading={loading}
        decoding="async"
        class="w-full h-auto block border border-border-code"
      />
    ) : (
      <img
        src={src as string}
        alt={alt || title || ""}
        title={title}
        loading={loading}
        decoding="async"
        class="w-full h-auto block border border-border-code"
      />
    )
  }
  {
    displayCaption && (
      <figcaption class="text-center text-sm text-text-muted italic">
        {displayCaption}
      </figcaption>
    )
  }
</figure>
