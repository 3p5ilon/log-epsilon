---
interface Props {
  src: string | { src: string };
  alt?: string;
  caption?: string;
  title?: string;
  class?: string;
}

const { src, alt = "", caption, title, class: className = "" } = Astro.props;
const imageSrc = typeof src === "object" ? src.src : src;
const displayCaption = caption || title;
---

<figure class={`my-6 space-y-2 ${className}`}>
  <img
    src={imageSrc}
    alt={alt || title || ""}
    title={title}
    loading="lazy"
    decoding="async"
    class="w-full h-auto block border border-border-code"
  />
  {
    displayCaption && (
      <figcaption class="text-center text-sm text-text-muted italic">
        {displayCaption}
      </figcaption>
    )
  }
</figure>
