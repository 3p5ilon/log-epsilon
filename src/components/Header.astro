---
import { NAV_LINKS } from "../consts";
import ThemeToggle from "./ThemeToggle.astro";

const currentPath = Astro.url.pathname;
---

<header class="mb-10 border-b border-dashed border-theme-divider pb-4">
  <nav aria-label="Main navigation" class="text-sm">
    <ul class="m-0 flex list-none flex-wrap items-center gap-3.5 p-0">
      {
        NAV_LINKS.map((item) => {
          const isActive = currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href));
          return (
            <li>
              <a
                href={item.href}
                class={`transition-colors duration-200 hover:text-theme-link ${isActive ? "font-semibold text-theme-link" : "text-text-main"}`}
              >
                [{item.label}]
              </a>
            </li>
          );
        })
      }
      <li class="sm:ml-auto">
        <ThemeToggle />
      </li>
    </ul>
  </nav>
</header>
