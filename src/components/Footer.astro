---
import { SITE, SOCIAL_LINKS } from "../consts";
import Badges from "./Badges.astro";

const currentPath = Astro.url.pathname;
---

<footer class="mt-20 text-sm">
  { (currentPath === "/" || currentPath === "/index.html") && (
    <div class="pb-5">
      <Badges />
    </div>
  ) }
  <div class="flex flex-wrap items-center justify-between gap-4 border-t border-dashed border-theme-divider pt-4">
    <ul class="m-0 flex list-none flex-wrap items-center gap-3.5 p-0">
      {
        SOCIAL_LINKS.map((link) => (
          <li>
            <a
              href={link.href}
              target={!link.href.startsWith("mailto:") && !link.href.startsWith("/") ? "_blank" : undefined}
              rel={!link.href.startsWith("mailto:") && !link.href.startsWith("/") ? "noreferrer" : undefined}
              class="transition-colors duration-200 text-text-main hover:text-theme-link"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
    <p class="text-text-main">@ {new Date().getFullYear()} {SITE.author}</p>
  </div>
</footer>
