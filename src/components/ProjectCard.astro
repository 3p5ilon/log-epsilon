---
import type { Project } from "../lib/projects";

type Props = Project;

const { title, description, tags, link } = Astro.props;
---

<a
  href={link || "#"}
  target={link ? "_blank" : "_self"}
  rel={link ? "noopener noreferrer" : ""}
  class="group block p-4 border border-border-main bg-transparent hover:border-border-hover transition-colors duration-200 h-full"
>
  <div class="flex flex-col h-full justify-between gap-3">
    <div>
      <h3 class="text-base font-bold font-mono text-theme-link">
        {title}
      </h3>
      <p class="text-sm font-mono text-text-muted mt-1.5 leading-relaxed">
        {description}
      </p>
    </div>
    <div class="flex flex-wrap gap-1.5 mt-auto pt-1">
      {
        tags.map((tag) => (
          <span class="border border-border-main px-1.5 py-0.5 text-[11px] font-mono text-text-muted bg-bg-muted">
            {tag}
          </span>
        ))
      }
    </div>
  </div>
</a>
