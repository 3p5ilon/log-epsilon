---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { SITE } from "../../consts";

const blogs = await getCollection("blog", ({ data }) => !data.draft);
const notes = await getCollection("notes", ({ data }) => !data.draft);
const allPosts = [...blogs, ...notes];

const tagCounts: Record<string, number> = {};
allPosts.forEach((post) => {
  post.data.tags?.forEach((tag: string) => {
    tagCounts[tag] = (tagCounts[tag] || 0) + 1;
  });
});

const tags = Object.keys(tagCounts).sort();
---

<Layout title="Tags" desc={`All tags used on ${SITE.title}.`}>
  <section class="space-y-8">
    <h1 class="text-2xl font-semibold">Tags</h1>
    <div class="flex flex-wrap gap-4 text-base">
      {
        tags.map((tag) => (
          <a
            href={`/tags/${tag}`}
            class="transition-colors duration-200 text-theme-accent hover:text-theme-link tabular-nums"
          >
            [{tag} ({tagCounts[tag]})]
          </a>
        ))
      }
    </div>
  </section>
</Layout>
